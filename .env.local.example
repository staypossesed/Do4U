# Copy to .env.local and fill in. Never commit .env.local.
#
# Supabase (client-safe)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (API routes / server actions) — not bundled for browser
SUPABASE_SERVICE_ROLE_KEY=

# AI providers
GROK_API_KEY=
OPENAI_API_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: for local scripts (e.g. scripts/verify-supabase-geo.ps1) — pooler URI from Supabase Connect
# URL-encode special characters in the password.
# DATABASE_URL=
# DIRECT_URL=

# Optional: external platform OAuth (see README)
# AVITO_CLIENT_ID=
# AVITO_CLIENT_SECRET=
# VK_APP_ID=
# VK_APP_SECRET=
# EBAY_CLIENT_ID=
# EBAY_CLIENT_SECRET=
# OLX_CLIENT_ID=
# OLX_CLIENT_SECRET=
# OLX_API_KEY=
